<!DOCTYPE html>
<html lang="zh-CN">
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>快速记事（布局优化版）</title>
<style>
*{box-sizing:border-box}
body{margin:0;padding:10px;background:#f6f6f6;font-family:system-ui,sans-serif;width:1440px;max-width:95vw;margin:0;}

.page-title{
  text-align:center;
  font-weight:bold;
  font-size:18px;
  color:#333;
  margin:8px 0 12px;
}

.top-container {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
  height: auto;
}

.student-area {
  flex: 1;
  background: #fff;
  border-radius: 8px;
  border: 1px solid #ddd;
  padding: 10px;
  overflow-y: auto;
}
.student-grid {
  display: grid;
  grid-template-columns: repeat(8,1fr);
  gap: 6px;
}
.student-item{
  padding:10px 6px;
  text-align:center;
  border:1px solid #ccc;
  border-radius:6px;
  background:#fff;
  font-size:14px;
  cursor:pointer;
}
.student-item.active{
  background:#4CAF50;
  color:#fff;
}

/* 功能区：6列 → 现在扩展为 7列 */
.func-area {
  width:600px;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  grid-template-rows: repeat(3, auto);
  gap:8px;
}
.func-area button,
.func-area input,
.func-area select {
  padding:10px 6px;
  font-size:14px;
  border-radius:6px;
  border:1px solid #ccc;
}
.func-area button {
  border:none;
  color:#fff;
  white-space:nowrap;
}

/* 空提示格子 */
.placeholder-tip{
  display:flex;align-items:center;justify-content:center;
  border:1px dashed #ccc;border-radius:6px;
  font-size:14px;color:#666;background:#fafafa;
}

/* 便签容器：5列，宽度与功能区完全对齐 */
.notes-container {
  width: 105%;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap:1px;
  margin-bottom:12px;
}

.note-card{
  background:#fff;
  border:1px solid #ddd;
  border-radius:8px;
  padding:10px;
  display:flex;
  flex-direction:column;
  gap:6px;
  overflow:hidden;
  height: 190px;
}

.note-header{
  position:relative;
  height: 48px;
}
.note-star{
  position:absolute;
  left:0;
  top:0;
  font-size:16px;
  z-index:2;
}
.note-title{
  font-size:15px;
  font-weight:bold;
  color:#2196F3;
  padding-left:24px;
  padding-right:60px;
  line-height:1.4;
  height:48px;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.note-time{
  position:absolute;
  right:0;
  bottom:0;
  font-size:13px;
  background:#eee;
  padding:3px 8px;
  border-radius:6px;
  white-space:nowrap;
}

.note-people{
  flex-grow:1;
  overflow-y:auto;
  font-size:13px;
}
.note-note{
  background:#f9f9f9;
  padding:4px 6px;
  border-radius:4px;
  font-size:13px;
}
.note-btns{
  display:flex;gap:4px;margin-top:auto;
}
.note-btns button{
  flex:1;padding:4px;font-size:13px;
}

.more-btn{
  width:105%;padding:12px;font-size:15px;background:#777;color:#fff;border:none;border-radius:6px;cursor:pointer;
}

button{background:#2196F3;color:white;border:none;cursor:pointer;border-radius:6px}
button.gray{background:#777}
button.red{background:#f44}
button.star{background:#FFB800;color:#222;font-weight:bold}
button.future{background:#999;color:white}

.pill{display:inline-block;padding:4px 6px;margin:2px;border-radius:4px;border:1px solid #ccc;font-size:13px}
.pill.active{background:#4CAF50;color:#fff}
.pill.inactive{background:#fff;color:#000}
.pill.leader{background:#fff;color:#2196F3;border:1px solid #2196F3}

.all-page,.star-page,.trash-page{display:none}

.modal{
  position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);
  display:none;justify-content:center;align-items:center;padding:10px;z-index:9999;
}
.modal-content{
  background:#fff;border-radius:12px;width:100%;max-width:420px;padding:20px;
}
.modal-title{font-weight:bold;margin-bottom:12px;font-size:16px}
.modal-textarea{width:100%;height:180px;padding:10px;border-radius:6px;border:1px solid #ccc;margin-bottom:8px}

#previewModal{z-index:9999;}
#editPeopleModal{z-index:9998;}
#editPeopleGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:15px 0;max-height:300px;overflow-y:auto;padding:10px;border:1px solid #eee;border-radius:8px;}
#editPeopleGrid .item{font-size:14px;padding:10px 4px;}
#noteModal{z-index:9997;}
#passwordModal{z-index:10000;}
.password-box{background:#fff;padding:24px;border-radius:12px;width:320px;text-align:center;}
.password-box input{margin:12px 0;text-align:center;font-size:16px;letter-spacing:4px;}

#adminIframeContainer{
  position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  width:960px;height:660px;background:#fff;border-radius:16px;box-shadow:0 0 24px rgba(0,0,0,0.2);
  z-index:9999;display:none;
}
#iframeHeader{
  height:42px;background:#9C27B0;color:#fff;padding:10px 16px;
  border-radius:16px 16px 0 0;cursor:move;
  display:flex;justify-content:space-between;align-items:center;
}
#closeIframeBtn{background:#fff;color:#9C27B0;border:none;border-radius:6px;padding:4px 10px;font-size:14px;cursor:pointer;}
#adminIframe{width:100%;height:calc(100% - 42px);border:none;}
</style>

<body>
<div class="main-page">
  <div class="page-title">快速记事（布局优化版）</div>

  <div class="top-container">
    <div class="student-area">
      <div class="student-grid" id="studentGrid"></div>
    </div>

    <div class="func-area">
      <!-- 第1行 -->
      <button onclick="generate()">生成</button>
      <input id="customInput" placeholder="手动输入标题">
      <select id="leaderSelect"></select>
      <button class="gray" onclick="clearSelected()">重选</button>
      <div class="placeholder-tip">请选择 →</div>
      <button class="future">待开发</button>
      <button class="future">待开发</button>

      <!-- 第2行 -->
      <button onclick="openStatusEdit()">自定选项</button>
      <select id="lv1" onchange="loadLv2()"></select>
      <select id="lv2" onchange="loadLv3()"></select>
      <select id="lv3" onchange="loadLv4()"></select>
      <select id="lv4"></select>
      <button class="future">待开发</button>
      <button class="gray" onclick="showAllPage()">全部</button>

      <!-- 第3行 -->
      <button onclick="openPeopleEdit()">自定名单</button>
      <button class="star" onclick="showStarPage()">收藏</button>
      <button class="gray" onclick="showTrashPage()">回收站</button>
      <button class="gray" onclick="openPasswordModal()">后台</button>
      <div></div>
      <div></div>
      <div></div>
    </div>
  </div>

  <div class="notes-container" id="notesContainer"></div>
  <button class="more-btn" onclick="loadMoreNotes()">加载更多</button>
</div>

<div class="all-page">
  <div style="display:flex;gap:10px;margin-bottom:12px;">
    <button class="gray" onclick="showMainPage()">返回</button>
    <button class="star" onclick="showStarPage()">收藏</button>
    <button class="red" onclick="clearAllRecords()">清空</button>
  </div>
  <div class="notes-container" id="allNotesContainer"></div>
</div>

<div class="star-page">
  <div style="display:flex;gap:10px;margin-bottom:12px;">
    <button class="gray" onclick="showMainPage()">返回</button>
    <button class="red" onclick="clearStarRecords()">清空收藏</button>
  </div>
  <div class="notes-container" id="starNotesContainer"></div>
</div>

<div class="trash-page">
  <div style="display:flex;gap:10px;margin-bottom:12px;">
    <button class="gray" onclick="showMainPage()">返回</button>
    <button class="red" onclick="clearTrash()">清空回收站</button>
  </div>
  <div class="notes-container" id="trashNotesContainer"></div>
</div>

<div id="previewModal" class="modal">
  <div class="modal-content">
    <div style="font-weight:bold;font-size:16px;margin-bottom:10px">复制成功</div>
    <div id="previewText"></div>
    <button style="margin-top:12px;padding:8px 16px" onclick="closePreview()">确定</button>
  </div>
</div>

<div id="editPeopleModal" class="modal">
  <div class="modal-content">
    <div class="modal-title">编辑记录</div>
    <textarea class="modal-textarea" id="editStatus"></textarea>
    <select id="editLeaderSelect" style="width:100%;padding:10px;border-radius:6px;border:1px solid #ccc;margin-bottom:10px;"></select>
    <div id="editPeopleGrid"></div>
    <div style="display:flex;gap:10px;margin-top:10px;">
      <button onclick="saveEditedPeople()">保存修改</button>
      <button class="gray" onclick="closeEditPeopleModal()">取消</button>
    </div>
  </div>
</div>

<div id="noteModal" class="modal">
  <div class="modal-content">
    <div class="modal-title">编辑备注</div>
    <textarea class="modal-textarea" id="noteInput"></textarea>
    <div style="display:flex;gap:10px;margin-top:10px;">
      <button onclick="saveNote()">保存</button>
      <button class="gray" onclick="closeNoteModal()">取消</button>
    </div>
  </div>
</div>

<div id="peopleModal" class="modal">
  <div class="modal-content">
    <div class="modal-title">编辑名单（一行一个）</div>
    <textarea class="modal-textarea" id="peopleText"></textarea>
    <div class="modal-title">编辑负责人</div>
    <textarea class="modal-textarea" id="leaderText"></textarea>
    <div style="display:flex;gap:10px;margin-top:10px;">
      <button onclick="savePeopleAndLeader()">保存</button>
      <button class="gray" onclick="closePeopleModal()">取消</button>
    </div>
  </div>
</div>

<div id="statusModal" class="modal">
  <div class="modal-content">
    <div class="modal-title">编辑4级选项（格式：1>2>3>4）</div>
    <textarea class="modal-textarea" id="statusText"></textarea>
    <div style="display:flex;gap:10px;margin-top:10px;">
      <button onclick="saveStatus()">保存</button>
      <button class="gray" onclick="closeStatusModal()">取消</button>
    </div>
  </div>
</div>

<div id="passwordModal" class="modal">
  <div class="password-box">
    <div style="font-weight:bold;margin-bottom:12px;">请输入后台密码</div>
    <input type="password" id="adminPassword" placeholder="??????">
    <div style="display:flex;gap:10px;margin-top:12px;">
      <button class="gray" onclick="closePasswordModal()">取消</button>
      <button onclick="checkAdminPassword()">确定</button>
    </div>
  </div>
</div>

<div id="adminIframeContainer">
  <div id="iframeHeader">
    后台面板
    <button id="closeIframeBtn" onclick="hideAdminIframe()">关闭</button>
  </div>
  <iframe id="adminIframe" src="houtai.html"></iframe>
</div>

<script>

// 监听iframe子页面发来的刷新指令
window.addEventListener('message', function(e) {
  // 只响应指定的刷新消息，避免误触发
  if (e.data?.type === 'REFRESH_PARENT') {
    // 强制刷新主页（不走缓存）
    window.location.reload(true);
  }
});

const STORAGE_KEY = 'jichibang_records';
const PEOPLE_KEY = 'cfg_people';
const LEADER_KEY = 'cfg_leader';
const STATUS_KEY = 'cfg_status4';
const TRASH_KEY = 'jichibang_trash';
const week = ["日","一","二","三","四","五","六"];

let currentEditIndex = -1;
let currentRecordPeopleMap = {};
let currentNoteIndex = -1;
let showLimit = 20;
const loadStep = 20;

function generateUniqueId(){
  const d = new Date();
  const Y = d.getFullYear();
  const M = String(d.getMonth()+1).padStart(2,'0');
  const D = String(d.getDate()).padStart(2,'0');
  const H = String(d.getHours()).padStart(2,'0');
  const m = String(d.getMinutes()).padStart(2,'0');
  return Y+M+D+H+m+Math.random().toString(36).substr(2,4);
}

function now(){
  const d = new Date();
  const wd = week[d.getDay()];
  const Y = d.getFullYear();
  const M = String(d.getMonth()+1).padStart(2,'0');
  const D = String(d.getDate()).padStart(2,'0');
  const hh = String(d.getHours()).padStart(2,'0');
  const mm = String(d.getMinutes()).padStart(2,'0');
  return Y+M+D+' '+hh+':'+mm+wd;
}

function showModal(id){
  hideAllModals();
  document.getElementById(id).style.display="flex";
}
function hideAllModals(){
  document.querySelectorAll('.modal').forEach(m=>m.style.display="none");
}
function closePreview(){hideAllModals()}
function closeEditPeopleModal(){hideAllModals();currentEditIndex=-1;currentRecordPeopleMap={}}
function closeNoteModal(){hideAllModals();currentNoteIndex=-1}
function closePeopleModal(){hideAllModals()}
function closeStatusModal(){hideAllModals()}
function closePasswordModal(){hideAllModals()}

let isDragging=false,dragX=0,dragY=0,winX=0,winY=0;
document.getElementById('iframeHeader').onmousedown=e=>{
  isDragging=true;
  dragX=e.clientX;dragY=e.clientY;
  const rect=document.getElementById('adminIframeContainer').getBoundingClientRect();
  winX=rect.left;winY=rect.top;
};
document.addEventListener('mousemove',e=>{
  if(!isDragging)return;
  const x=winX+e.clientX-dragX;
  const y=winY+e.clientY-dragY;
  const el=document.getElementById('adminIframeContainer');
  el.style.left=x+'px';
  el.style.top=y+'px';
});
document.addEventListener('mouseup',()=>isDragging=false);

function showAdminIframe(){document.getElementById('adminIframeContainer').style.display='block'}
function hideAdminIframe(){document.getElementById('adminIframeContainer').style.display='none';location.reload();}
function openPasswordModal(){showModal('passwordModal');document.getElementById('adminPassword').value='';}
function checkAdminPassword(){
  if(document.getElementById('adminPassword').value==='666666'){hideAllModals();showAdminIframe();}else{alert('密码错误');}
}

function getTrash(){try{return JSON.parse(localStorage.getItem(TRASH_KEY))||[]}catch{return[]}}
function setTrash(arr){localStorage.setItem(TRASH_KEY,JSON.stringify((arr||[]).slice(-100)))}
function addToTrash(item){const t=getTrash();t.push(item);setTrash(t)}
function addManyToTrash(items){const t=getTrash();t.push(...items);setTrash(t)}

function getPeopleText(){return localStorage.getItem(PEOPLE_KEY)||"人1\n人2\n人3\n人4\n人5"}
function setPeopleText(t){localStorage.setItem(PEOPLE_KEY,t)}
function getPeople(){return getPeopleText().split('\n').map(i=>i.trim()).filter(Boolean)}
function getLeaderText(){return localStorage.getItem(LEADER_KEY)||"组长A\n组长B\n组长C"}
function setLeaderText(t){localStorage.setItem(LEADER_KEY,t)}
function getLeaders(){return getLeaderText().split('\n').map(i=>i.trim()).filter(Boolean)}

function getStatusText(){return localStorage.getItem(STATUS_KEY)||`出勤>上午>第一节>正常
出勤>上午>第一节>迟到
出勤>上午>第二节>正常
出勤>下午>第三节>正常
请假>病假>居家>康复中
请假>事假>外出>处理私事`}
function setStatusText(t){localStorage.setItem(STATUS_KEY,t)}
function getStatusTree(){
  const t={};
  getStatusText().split('\n').map(i=>i.trim()).filter(Boolean).forEach(line=>{
    const [a,b,c,d]=line.split('>').map(i=>i.trim()).filter(Boolean);
    if(!a)return;if(!t[a])t[a]={};if(!t[a][b])t[a][b]={};if(!t[a][b][c])t[a][b][c]=[];if(d)t[a][b][c].push(d);
  });
  return t;
}

function getRecords(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||[]}catch{return[]}}
function setRecords(r){localStorage.setItem(STORAGE_KEY,JSON.stringify(r||[]))}

function loadLeaderSelect(){
  const s=document.getElementById('leaderSelect');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选负责人';s.appendChild(o);
  getLeaders().forEach(n=>{const opt=document.createElement('option');opt.value=n;opt.textContent=n;s.appendChild(opt);});
}

function loadLv1(){
  const t=getStatusTree(),s=document.getElementById('lv1');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选择';s.appendChild(o);
  Object.keys(t).forEach(k=>{const opt=document.createElement('option');opt.value=k;opt.textContent=k;s.appendChild(opt);});
  loadLv2();
}
function loadLv2(){
  const t=getStatusTree(),v=document.getElementById('lv1').value,s=document.getElementById('lv2');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选择';s.appendChild(o);
  if(v&&t[v])Object.keys(t[v]).forEach(k=>{const opt=document.createElement('option');opt.value=k;opt.textContent=k;s.appendChild(opt);});
  loadLv3();
}
function loadLv3(){
  const t=getStatusTree(),a=document.getElementById('lv1').value,b=document.getElementById('lv2').value,s=document.getElementById('lv3');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选择';s.appendChild(o);
  if(a&&b&&t[a]&&t[a][b])Object.keys(t[a][b]).forEach(k=>{const opt=document.createElement('option');opt.value=k;opt.textContent=k;s.appendChild(opt);});
  loadLv4();
}
function loadLv4(){
  const t=getStatusTree(),a=document.getElementById('lv1').value,b=document.getElementById('lv2').value,c=document.getElementById('lv3').value,s=document.getElementById('lv4');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选择';s.appendChild(o);
  if(a&&b&&c&&t[a]&&t[a][b]&&t[a][b][c])t[a][b][c].forEach(k=>{const opt=document.createElement('option');opt.value=k;opt.textContent=k;s.appendChild(opt);});
}

function renderStudents(){
  const g=document.getElementById('studentGrid');g.innerHTML='';
  getPeople().forEach(n=>{
    const d=document.createElement('div');d.className='student-item';d.textContent=n;
    d.onclick=()=>d.classList.toggle('active');
    g.appendChild(d);
  });
}

function openPeopleEdit(){document.getElementById('peopleText').value=getPeopleText();document.getElementById('leaderText').value=getLeaderText();showModal('peopleModal');}
function openStatusEdit(){document.getElementById('statusText').value=getStatusText();showModal('statusModal');}
function savePeopleAndLeader(){setPeopleText(document.getElementById('peopleText').value);setLeaderText(document.getElementById('leaderText').value);closePeopleModal();renderAll();}
function saveStatus(){setStatusText(document.getElementById('statusText').value);closeStatusModal();renderAll();}

function generate(){
  const txt=document.getElementById('customInput').value.trim();
  const lead=document.getElementById('leaderSelect').value;
  const a=document.getElementById('lv1').value,b=document.getElementById('lv2').value,c=document.getElementById('lv3').value,d=document.getElementById('lv4').value;
  const sel=[...document.querySelectorAll('.student-item.active')].map(i=>i.textContent);
  if(!sel.length){alert('请选择人物');return;}
  const parts=[a,b,c,d].filter(Boolean);
  if(!txt&&!parts.length){alert('请输入标题或选择状态');return;}
  const title=txt||parts.join(' - ');
  const r=getRecords();
  r.unshift({id:generateUniqueId(),time:now(),status:title,people:sel.map(n=>({name:n,active:true})),leader:lead,note:'',star:false});
  setRecords(r);
  document.getElementById('customInput').value='';
  document.getElementById('leaderSelect').selectedIndex=0;
  clearSelected();loadLv1();renderNotes();alert('已生成');
}

function clearSelected(){document.querySelectorAll('.student-item.active').forEach(i=>i.classList.remove('active'));}
function loadMoreNotes(){showLimit+=20;renderNotes();}

function copyRecord(r){
  const ns=r.people.filter(o=>o.active).map(o=>o.name);
  if(!ns.length){alert('暂无激活人员');return;}
  const s=`${ns.join('、')}，${r.status}${r.leader?' 负责人：'+r.leader:''}`;
  navigator.clipboard.writeText(s);
  document.getElementById('previewText').innerText=s;
  showModal('previewModal');
}

function openEditPeopleModal(i){
  currentEditIndex=i;
  const r=getRecords()[i];
  currentRecordPeopleMap={};
  r.people.forEach(o=>currentRecordPeopleMap[o.name]=o.active);
  const g=document.getElementById('editPeopleGrid');g.innerHTML='';
  getPeople().forEach(n=>{
    const d=document.createElement('div');d.className='item';
    if(currentRecordPeopleMap[n])d.classList.add('active');
    d.textContent=n;
    d.onclick=()=>d.classList.toggle('active');
    g.appendChild(d);
  });
  document.getElementById('editStatus').value=r.status||'';
  const s=document.getElementById('editLeaderSelect');s.innerHTML='';
  const o=document.createElement('option');o.value='';o.textContent='不选负责人';s.appendChild(o);
  getLeaders().forEach(n=>{const opt=document.createElement('option');opt.value=n;opt.textContent=n;if(n===r.leader)opt.selected=true;s.appendChild(opt);});
  showModal('editPeopleModal');
}

function saveEditedPeople(){
  if(currentEditIndex===-1)return;
  const t=document.getElementById('editStatus').value.trim();
  if(!t){alert('标题不能为空');return;}
  const rs=getRecords();
  const r=rs[currentEditIndex];
  const sel=[...document.querySelectorAll('#editPeopleGrid .item.active')].map(i=>i.textContent.trim()).filter(Boolean);
  r.people=sel.map(n=>({name:n,active:currentRecordPeopleMap[n]??true}));
  r.status=t;
  r.leader=document.getElementById('editLeaderSelect').value;
  setRecords(rs);
  closeEditPeopleModal();
  renderNotes();
  renderStarNotes();
  alert('修改成功');
}

function openNoteModal(i){currentNoteIndex=i;document.getElementById('noteInput').value=(getRecords()[i]||{}).note||'';showModal('noteModal');}
function saveNote(){if(currentNoteIndex===-1)return;const rs=getRecords();rs[currentNoteIndex].note=document.getElementById('noteInput').value.trim();setRecords(rs);closeNoteModal();renderNotes();renderStarNotes();}

function toggleStar(i){const rs=getRecords();rs[i].star=!rs[i].star;setRecords(rs);renderNotes();renderStarNotes();}

function showMainPage(){
  document.querySelector('.main-page').style.display='block';
  document.querySelector('.all-page').style.display='none';
  document.querySelector('.star-page').style.display='none';
  document.querySelector('.trash-page').style.display='none';
}
function showAllPage(){
  document.querySelector('.main-page').style.display='none';
  document.querySelector('.all-page').style.display='block';
  document.querySelector('.star-page').style.display='none';
  document.querySelector('.trash-page').style.display='none';
  renderAllNotes();
}
function showStarPage(){
  document.querySelector('.main-page').style.display='none';
  document.querySelector('.all-page').style.display='none';
  document.querySelector('.star-page').style.display='block';
  document.querySelector('.trash-page').style.display='none';
  renderStarNotes();
}
function showTrashPage(){
  document.querySelector('.main-page').style.display='none';
  document.querySelector('.all-page').style.display='none';
  document.querySelector('.star-page').style.display='none';
  document.querySelector('.trash-page').style.display='block';
  renderTrashNotes();
}

function clearAllRecords(){if(!confirm('确定清空全部记录？'))return;const r=getRecords();addManyToTrash(r);localStorage.removeItem(STORAGE_KEY);renderNotes();renderAllNotes();}
function clearStarRecords(){if(!confirm('确定清空收藏？'))return;const r=getRecords();r.forEach(i=>i.star=false);setRecords(r);renderNotes();renderStarNotes();}
function clearTrash(){if(!confirm('确定清空回收站？'))return;localStorage.removeItem(TRASH_KEY);renderTrashNotes();}

function restoreFromTrash(i){const t=getTrash();const it=t[i];if(!it)return;const r=getRecords();if(r.some(j=>j.id===it.id)){alert('已存在');return;}t.splice(i,1);setTrash(t);r.unshift(it);setRecords(r);renderTrashNotes();renderNotes();renderStarNotes();}
function deleteFromTrash(i){if(!confirm('确定删除？'))return;const t=getTrash();t.splice(i,1);setTrash(t);renderTrashNotes();}

function makeNoteCard(i,isTrash=false){
  const rs=isTrash?getTrash():getRecords();
  const r=rs[i];
  const c=document.createElement('div');c.className='note-card';
  const h=document.createElement('div');h.className='note-header';
  const star=document.createElement('div');star.className='note-star';star.textContent=r.star?'★':'☆';
  if(!isTrash)star.onclick=()=>toggleStar(i);
  const title=document.createElement('div');title.className='note-title';title.textContent=r.status;
  const time=document.createElement('div');time.className='note-time';time.textContent=r.time;
  h.append(star,title,time);c.appendChild(h);
  const p=document.createElement('div');p.className='note-people';
  r.people.forEach(o=>{
    const span=document.createElement('span');
    span.className='pill '+(o.active?'active':'inactive');
    span.textContent=o.name;
    if(!isTrash)span.onclick=()=>{o.active=!o.active;setRecords(rs);renderNotes();renderStarNotes();};
    p.appendChild(span);
  });
  if(r.leader){const sp=document.createElement('span');sp.className='pill leader';sp.textContent=r.leader;p.appendChild(sp);}
  c.appendChild(p);
  if(r.note){const n=document.createElement('div');n.className='note-note';n.textContent=r.note;c.appendChild(n);}
  const b=document.createElement('div');b.className='note-btns';
  if(isTrash){
    const res=document.createElement('button');res.className='red';res.textContent='撤回';res.onclick=()=>restoreFromTrash(i);
    const del=document.createElement('button');del.className='red';del.textContent='删除';del.onclick=()=>deleteFromTrash(i);
    b.append(res,del);
  }else{
    const e=document.createElement('button');e.className='gray';e.textContent='编辑';e.onclick=()=>openEditPeopleModal(i);
    const cp=document.createElement('button');cp.className='gray';cp.textContent='复制';cp.onclick=()=>copyRecord(r);
    const n=document.createElement('button');n.className='gray';n.textContent='备注';n.onclick=()=>openNoteModal(i);
    const d=document.createElement('button');d.className='red';d.textContent='删除';d.onclick=()=>{if(!confirm('确定删除？'))return;const all=getRecords();const item=all.splice(i,1)[0];addToTrash(item);setRecords(all);renderNotes();renderStarNotes();};
    b.append(e,cp,n,d);
  }
  c.appendChild(b);
  return c;
}

function renderNotes(){
  const b=document.getElementById('notesContainer');b.innerHTML='';
  getRecords().slice(0,showLimit).forEach((_,i)=>b.appendChild(makeNoteCard(i)));
}
function renderAllNotes(){
  const b=document.getElementById('allNotesContainer');b.innerHTML='';
  getRecords().forEach((_,i)=>b.appendChild(makeNoteCard(i)));
}
function renderStarNotes(){
  const b=document.getElementById('starNotesContainer');b.innerHTML='';
  getRecords().filter(r=>r.star).forEach((_,i)=>b.appendChild(makeNoteCard(i)));
}
function renderTrashNotes(){
  const b=document.getElementById('trashNotesContainer');b.innerHTML='';
  getTrash().forEach((_,i)=>b.appendChild(makeNoteCard(i,true)));
}

function renderAll(){
  renderStudents();
  loadLeaderSelect();
  loadLv1();
  renderNotes();
}

window.onload=renderAll;
</script>
</body>
</html>
